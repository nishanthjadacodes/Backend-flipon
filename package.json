{
  "name": "flipon-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for FlipOn Digital platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:admin": "node scripts/migrateAdminSchema.js",
    "seed:admin": "node scripts/seedAdminRoles.js",
    "seed:admins": "node scripts/seedAdminUsers.js",
    "seed:superadmin": "node scripts/seedSuperAdmin.js",
    "admin:bootstrap": "npm run migrate:admin && npm run seed:admin && npm run seed:admins",
    "seed:aadhaar": "node scripts/seedAadhaarServices.js",
    "seed:welfare": "node scripts/seedWelfareServices.js",
    "seed:certificate": "node scripts/seedCertificateServices.js",
    "seed:state": "node scripts/seedStateSchemes.js",
    "seed:additional": "node scripts/seedAdditionalServices.js",
    "seed:all": "npm run seed:admin && npm run seed:superadmin && npm run seed:aadhaar && npm run seed:welfare && npm run seed:certificate && npm run seed:state && npm run seed:additional",
    "seed:complete": "node scripts/seedAllServices.js",
    "seed:new": "node scripts/seedNewServices.js",
    "seed:sql": "node scripts/seedAllServicesSQL.js",
    "update:remaining": "node scripts/updateAllRemainingServices.js",
    "cleanup:services": "node scripts/cleanupTestServices.js",
    "reset:services": "npm run cleanup:services && npm run seed:sql",
    "bootstrap:prod": "node scripts/bootstrapProduction.js"
  },
  "keywords": [
    "flipon",
    "digital",
    "platform",
    "backend",
    "api"
  ],
  "author": "FlipOn Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.2",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.6.5",
    "razorpay": "^2.9.6",
    "sequelize": "^6.35.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
