# Port — Railway/Render inject PORT automatically, keep 3001 only for local
PORT=3001

# Sign your JWTs — generate a long random string for production
# (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-in-production

# Database (Railway MySQL plugin injects these automatically;
# locally, point at your MySQL instance)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=flipon_db
DB_USER=root
DB_PASSWORD=

# 'production' disables the dev-OTP fallback that returns the OTP in the
# response body. Use 'production' in deployed envs.
NODE_ENV=development

# Fast2SMS — https://www.fast2sms.com  →  Dev API → Authorization
# Required for real SMS in production. Without it the backend falls back
# to console-logged OTPs (and to `devOtp` in responses when NODE_ENV!=production).
FAST2SMS_API_KEY=
