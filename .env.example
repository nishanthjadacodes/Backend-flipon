# Port — Railway/Render inject PORT automatically, keep 3001 only for local
PORT=3001

# Sign your JWTs — generate a long random string for production
# (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-in-production

# Database (Railway MySQL plugin injects these automatically;
# locally, point at your MySQL instance)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=flipon_db
DB_USER=root
DB_PASSWORD=

# 'production' disables the dev-OTP fallback that returns the OTP in the
# response body. Use 'production' in deployed envs.
NODE_ENV=development

# OTP delivery provider — explicit so we don't piggyback on NODE_ENV.
#   hardcoded (default) — no SMS sent, OTP is returned in the response body.
#                          Free; for internal testing.
#   fast2sms            — real SMS via Fast2SMS DLT route. Requires all four
#                          FAST2SMS_* vars below to be filled in.
OTP_PROVIDER=hardcoded

# Fast2SMS — https://www.fast2sms.com  →  Dev API → Authorization
# Required for real SMS in production. Without it the backend falls back
# to console-logged OTPs (and to `devOtp` in responses when NODE_ENV!=production).
FAST2SMS_API_KEY=

# DLT route name — 'dlt' for transactional templates (production OTPs in
# India), 'otp' for the quick-OTP route (only works without DLT for some
# accounts; not reliable for prod).
FAST2SMS_ROUTE=dlt

# 6-character DLT-approved sender ID (e.g. FLIPNX). Must match what was
# registered on the DLT portal — anything else gets rejected at the gateway.
FAST2SMS_SENDER_ID=

# Numeric DLT message/template ID. The template MUST define two variables
# in this order: {OTP}|{businessName}. The backend substitutes them as
# `${otpCode}|FliponeX`.
FAST2SMS_TEMPLATE_ID=

# Razorpay — https://dashboard.razorpay.com  →  Account & Settings → API Keys
# Use rzp_test_... keys for development. For production, generate LIVE keys
# (requires KYC) and set them via the Render dashboard, not in this file.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Vault encryption key — AES-256-GCM, 32 bytes hex.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: production key must be different from dev key, and must be
# backed up securely — losing it makes all encrypted vault documents
# unrecoverable. Set via Render Environment tab, not here.
VAULT_ENCRYPTION_KEY=
